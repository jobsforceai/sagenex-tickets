<section class="form-panel narrow">
  <h1><%= mode === 'invite' ? 'Accept Developer Invite' : 'Reset Password' %></h1>
  <form method="post" action="<%= mode === 'invite' ? '/accept-invite/' + token : '/reset-password/' + token %>">
    <label>New Password<input name="password" type="password" minlength="8" required></label>
    <button class="btn-primary"><%= mode === 'invite' ? 'Activate Account' : 'Update Password' %></button>
  </form>
</section>
