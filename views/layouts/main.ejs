<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#1f3a5f">
  <title><%= title %> | Sagenex</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
</head>
<body class="<%= title === 'Raise Complaint' ? 'complaint-page' : '' %>">
  <%- include('../partials/header') %>
  <main class="app-shell">
    <% if (currentUser && currentUser.role !== 'user') { %><%- include('../partials/sidebar') %><% } %>
    <section class="content-pane">
      <% if (flash) { %><div class="alert alert-<%= flash.type %> py-2 small"><%= flash.message %></div><% } %>
      <%- body %>
      <%- include('../partials/footer') %>
    </section>
  </main>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
