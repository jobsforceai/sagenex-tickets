<header class="topbar">
  <a class="brand" href="<%= currentUser?.role === 'admin' ? '/admin/dashboard' : currentUser?.role === 'developer' ? '/developer/dashboard' : '/' %>">Sagenex Ticketing System</a>
  <button type="button" class="menu-toggle" id="menuToggle" aria-label="Open navigation" aria-controls="topnav" aria-expanded="false">☰</button>
  <nav class="topnav">
    <button type="button" class="drawer-close" id="drawerClose" aria-label="Close navigation">×</button>
    <% if (currentUser) { %>
      <% if (currentUser.role === 'admin') { %>
        <a class="<%= currentPath.startsWith('/admin/dashboard') ? 'active' : '' %>" href="/admin/dashboard">Dashboard</a>
        <a class="<%= currentPath.startsWith('/admin/tickets') ? 'active' : '' %>" href="/admin/tickets">Tickets</a>
        <a class="<%= currentPath.startsWith('/admin/developers') ? 'active' : '' %>" href="/admin/developers">Developers</a>
        <a class="<%= currentPath.startsWith('/admin/reports') ? 'active' : '' %>" href="/admin/reports">Reports</a>
      <% } else if (currentUser.role === 'developer') { %>
        <a class="<%= currentPath.startsWith('/developer/dashboard') ? 'active' : '' %>" href="/developer/dashboard">Dashboard</a>
        <a class="<%= currentPath.startsWith('/developer/tickets') ? 'active' : '' %>" href="/developer/tickets">Assigned Tickets</a>
      <% } %>
      <span class="user-chip"><%= currentUser.name %> · <%= currentUser.role %></span>
      <form method="post" action="/logout"><button class="link-btn">Logout</button></form>
    <% } else { %>
      <a class="<%= currentPath === '/' ? 'active' : '' %>" href="/">Home</a>
      <a class="<%= currentPath.startsWith('/complaint') ? 'active' : '' %>" href="/complaint">Raise Complaint</a>
      <a class="<%= currentPath.startsWith('/track') ? 'active' : '' %>" href="/track">Track</a>
      <a class="<%= currentPath.startsWith('/login') ? 'active' : '' %>" href="/login">Login</a>
    <% } %>
  </nav>
  <div class="nav-backdrop" id="navBackdrop"></div>
</header>
