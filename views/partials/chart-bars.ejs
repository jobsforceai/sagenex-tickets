<% 
  const rows = data || [];
  const max = Math.max(1, ...rows.map((row) => row.count || 0));
%>
<section class="chart-card">
  <h2><%= title %></h2>
  <% if (!rows.length) { %>
    <div class="empty-state">No data available.</div>
  <% } else { %>
    <div class="bar-list">
      <% rows.forEach(function(row) { 
        const label = row._id || 'Unknown';
        const percent = Math.max(4, Math.round(((row.count || 0) / max) * 100));
      %>
        <div class="bar-row">
          <div class="bar-label"><span><%= label %></span><b><%= row.count %></b></div>
          <div class="bar-track"><span style="width:<%= percent %>%"></span></div>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>
